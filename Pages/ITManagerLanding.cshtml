@page
@model IMS.Pages.ITManagerLandingModel
@{
  ViewData["Title"] = "IT Manager Dashboard";
}

<div class="container-fluid py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2>IT Manager Dashboard - User Accounts</h2>
    <form method="post">
      <button type="submit" asp-page-handler="Logout" class="btn btn-danger">Log Out</button>
    </form>
  </div>

  <!-- User Accounts Table -->
  <div class="card shadow-sm">
    <div class="card-body">
      <table class="table table-striped align-middle">
        <thead class="table-primary">
          <tr>
            <th scope="col">Username</th>
            <th scope="col">Account Type</th>
            <th scope="col">Verified Status</th>
            <th scope="col">Actions</th>
          </tr>
        </thead>
        <tbody>
          @foreach (var account in Model.UnverifiedAccounts)
          {
            <tr>
              <td>@account.Username</td>
              <td>@(account.Is_IT_User ? "IT User" : "General User")</td>
              <td>
                <span class="badge @(account.Verified ? "bg-success" : "bg-warning text-dark")">
                  @(account.Verified ? "Verified" : "Unverified")
                </span>
              </td>
              <td>
                <form method="post" asp-page-handler="Verify" asp-route-id="@account.Account_Id" class="d-inline-block">
                  <button class="btn btn-sm btn-success">Verify</button>
                </form>
                <button class="btn btn-sm btn-danger" onclick="confirmDeletion(@account.Account_Id, '@account.Username')">
                  Delete
                </button>
              </td>
            </tr>
          }
        </tbody>
      </table>
      @if (!Model.UnverifiedAccounts.Any())
      {
        <div class="text-center text-muted">No unverified accounts.</div>
      }
    </div>
  </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteAccountModal" tabindex="-1">
  <div class="modal-dialog">
    <form method="post" asp-page-handler="Delete" class="modal-content">
      <div class="modal-header bg-danger text-white">
        <h5 class="modal-title">Confirm Account Deletion</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <input type="hidden" id="deleteAccountId" name="id" />
        <p>Are you sure you want to permanently delete the account "<strong id="deleteAccountName"></strong>"?</p>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="btn btn-danger">Delete Account</button>
      </div>
    </form>
  </div>
</div>

@section Scripts {
  <script>
    function confirmDeletion(accountId, username) {
      document.getElementById('deleteAccountId').value = accountId;
      document.getElementById('deleteAccountName').textContent = username;
      var modal = new bootstrap.Modal(document.getElementById('deleteAccountModal'));
      modal.show();
    }
  </script>
}
