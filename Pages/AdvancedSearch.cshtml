@page
@model IMS.Pages.AdvancedSearchModel
@{
  ViewData["Title"] = "Advanced Search";
}

<style>
    .text-danger {
        white-space: pre-line;
    }
</style>

<div class="container d-flex flex-column justify-content-center align-items-center" style="min-height: 100vh;">
  <div class="w-100" style="max-width: 400px;">
    <div class="text-center mb-4">
      <h1>Advanced Search</h1>
      <p class="lead">Please fill in the relevant search fields</p>
    </div>
    @if (ViewData.ModelState[""] != null){
    <div class="alert @("alert-danger")">
      @ViewData.ModelState[""].Errors[0].ErrorMessage
    </div>
    }
    <form method="post" enctype="multipart/form-data">
      <div class="form-group">
        <label asp-for="Input.ProductName">Product Name</label>
        <input asp-for="Input.ProductName" class="form-control"/>
        <span asp-validation-for="Input.ProductName" class="text-danger"></span>
      </div>
      <div class="form-group">
        <label asp-for="Input.Description"></label>
        <textarea asp-for="Input.Description" class="form-control"></textarea>
        <span asp-validation-for="Input.Description" class="text-danger"></span> 
      </div>
    <div class="form-group">
        <label asp-for="Input.PriceOperator">Price Comparison:</label>
        <select name="PriceOperator" id="PriceOperator" asp-for="Input.PriceOperator" class="form-control">
            <option value="=" selected>=</option>
            <option value=">">&gt;</option>
            <option value=">=">&ge;</option>
            <option value="<">&lt;</option>
            <option value="<=">&le;</option>
        </select>
      </div>
      <div class="form-group">
        <label asp-for="Input.Price"></label>
        <input type="text" asp-for="Input.Price" class="form-control" />
        <span asp-validation-for="Input.Price" class="text-danger"></span>
      </div>
      <div class="form-group">
        <label asp-for="Input.QuantityOperator">Quantity Comparison:</label>
        <select name="QuantityOperator" id="QuantityOperator" asp-for="Input.QuantityOperator" class="form-control">
            <option value="=" selected>=</option>
            <option value=">">&gt;</option>
            <option value=">=">&ge;</option>
            <option value="<">&lt;</option>
            <option value="<=">&le;</option>
        </select>
      </div>
      <div class="form-group">
        <label asp-for="Input.Quantity"></label>
        <input type="text" asp-for="Input.Quantity" class="form-control" />
        <span asp-validation-for="Input.Quantity" class="text-danger"></span>
      </div>
      <div class="form-group">
        <label asp-for="Input.SKU"></label>
        <input asp-for="Input.SKU" class="form-control" />
        <span asp-validation-for="Input.SKU" class="text-danger"></span>
      </div>
      <div class="form-group">
        <label asp-for="Input.Category"></label>
        <input type="search" list="Categories" asp-for="Input.Category" placeholder="Enter a Category" class="form-control" />
        <datalist id="Categories">
          @foreach (var category in Model.Categories)
          {
            <option value="@category"></option>
          }
        </datalist>
        <span asp-validation-for="Input.Category" class="text-danger"></span>
      </div>
      <div class="form-group">
        <label asp-for="Input.Location"></label>
        <input type="search" list="Locations" asp-for="Input.Location" placeholder="Enter a Location" class="form-control" />
        <datalist id="Locations">
          @foreach (var location in Model.Locations)
          {
            <option value="@location"></option>
          }
        </datalist>
        <span asp-validation-for="Input.Location" class="text-danger"></span>
      </div>
      <div class="d-flex justify-content-between mt-3">
        <button type="submit" class="btn btn-primary">Search</button>
        <a href="/Products" class="btn btn-secondary">Cancel</a>
      </div>
    </form>
  </div>
</div>
