@page
@model IMS.Pages.InventoryManagerLandingModel
@{
  ViewData["Title"] = "Inventory Manager Dashboard";
}

<div class="container-fluid py-4">

  <!-- Header with Log Out Button -->
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Inventory Manager Dashboard</h1>
    <form method="post">
      <button type="submit" asp-page-handler="Logout" class="btn btn-danger">Log Out</button>
    </form>
  </div>

  <!-- Quick Info Bar -->
  <div class="row mb-4">
    <div class="col-md-4">
      <h4>Weather</h4>
      <div id="weather-widget" class="border p-3">
        Fetching Weather...
      </div>
    </div>
    <div class="col-md-4 text-center">
      <h4>Current Date & Time</h4>
      <div class="border p-3">
        <p id="live-clock"></p>
      </div>
    </div>
    <div class="col-md-4 text-end">
      <h4>Quick Actions</h4>
      <button class="btn btn-success me-2">Order Products</button>
      <button class="btn btn-info" data-bs-toggle="modal" data-bs-target="#scannerModal">Launch Scanner</button>
    </div>
  </div>

  <!-- Visual Graphical Selection -->
  <div class="d-flex justify-content-between align-items-center mb-4">
    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#exportModal">Export Data</button>
  </div>

  <div class="modal fade" id="exportModal" tabindex="-1" aria-labelledby="exportModalLabel" aria-hidden="true">
    <div class="modal-dialog">
      <div class="modal-content p-3">
        <div class="modal-header">
          <h5 class="modal-title" id="exportModalLabel">Export Graph</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <label for="exportChartType">Choose chart:</label>
          <select id="exportChartType" class="form-select mb-3">
            <option value="stockBarChart">Stock Bar Chart</option>
            <option value="categoryPieChart">Category Pie Chart</option>
            <option value="reorderLineChart">Reorder Level Line Chart</option>
            <option value="priceQuantityScatter">Price vs Quantity Scatter</option>
          </select>
          <button class="btn btn-success w-100" onclick="downloadChart()">Download PNG</button>
        </div>
      </div>
    </div>
  </div>

  <!-- Chart Switcher -->
  <div class="mb-3">
    <label for="chartTypeSelector" class="form-label">Select Chart Type:</label>
    <select class="form-select" id="chartTypeSelector" onchange="switchChart(this.value)">
      <option value="">-- Select --</option>
      <option value="stock">Stock Bar Chart</option>
      <option value="category">Category Pie Chart</option>
      <option value="reorder">Reorder vs Quantity Line</option>
      <option value="scatter">Price vs Quantity</option>
    </select>
  </div>

  <div id="loadingSpinner" style="display:none;">
    <p><strong>Graph being generated...</strong></p>
  </div>

  <div id="chartContainer">
    <!-- Chart canvases (can be hidden/revealed based on selection) -->
    <canvas id="stockBarChart" style="display:none;"></canvas>
    <canvas id="categoryPieChart" style="display:none;"></canvas>
    <canvas id="reorderLineChart" style="display:none;"></canvas>
    <canvas id="priceQuantityScatter" style="display:none;"></canvas>
  </div>



  <!-- Quick Product Search -->
  <div class="row mb-4">
    <div class="col-md-6">
      <h4>Quick Product Search</h4>
      <form method="get">
        <input type="text" name="SearchTerm" value="@Model.SearchTerm" class="form-control"
          placeholder="Search products..." />
        <button type="submit" class="btn btn-primary mt-2">Search</button>
      </form>
      @if (!string.IsNullOrEmpty(Model.SearchTerm))
      {
        if (Model.Products.Any())
        {
          <ul class="list-group mt-2">
            @foreach (var product in Model.Products)
            {
              <li class="list-group-item">
                <strong>@product.Name</strong> - $@product.Price, Qty: @product.Quantity
              </li>
            }
          </ul>
        }
        else
        {
          <p>No products found.</p>
        }
      }
    </div>
  </div>

  <!-- Notes Section -->
  <div class="row mb-4">
    <div class="col-md-6">
      <h4>Notes</h4>
      <form method="post" asp-page-handler="AddNote">
        <textarea name="NewNote" class="form-control" placeholder="Enter note..." rows="3"></textarea>
        <button type="submit" class="btn btn-secondary mt-2">Save Note</button>
      </form>
      <ul class="list-group mt-3">
        @foreach (var note in Model.Notes)
        {
          <li class="list-group-item d-flex justify-content-between align-items-center">
            <div>
              <small>@DateTime.Parse(note.Timestamp).ToString("f")</small>
              <p>@note.Content</p>
            </div>
            <div>
              <button class="btn btn-sm btn-warning" onclick="openEditModal(@note.Id, '@note.Content')">Edit</button>
              <form method="post" asp-page-handler="DeleteNote" asp-route-id="@note.Id" class="d-inline-block">
                <button type="submit" class="btn btn-sm btn-danger">Delete</button>
              </form>
            </div>
          </li>
        }
      </ul>
    </div>
  </div>

  <!-- Interactive Calendar -->
  <div class="row mb-5">
    <div class="col-md-12">
      <h4>
        Interactive Calendar -
        <button id="prev-month" class="btn btn-sm btn-secondary">&lt;</button>
        <span id="current-month-year"></span>
        <button id="next-month" class="btn btn-sm btn-secondary">&gt;</button>
      </h4>
      <table class="table table-bordered">
        <thead class="table-primary">
          <tr>
            <th>Sun</th>
            <th>Mon</th>
            <th>Tue</th>
            <th>Wed</th>
            <th>Thu</th>
            <th>Fri</th>
            <th>Sat</th>
          </tr>
        </thead>
        <tbody id="calendar-body"></tbody>
      </table>
    </div>
  </div>

  <!-- Note Viewing Modal -->
  <div class="modal fade" id="calendarNoteModal" tabindex="-1">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header bg-info text-white">
          <h5 class="modal-title">Notes on <span id="modal-date"></span></h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body" id="modal-notes-content">
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
        </div>
      </div>
    </div>
  </div>

  <!-- Edit Note Modal -->
  <div class="modal fade" id="editNoteModal" tabindex="-1">
    <div class="modal-dialog">
      <form method="post" asp-page-handler="EditNote" class="modal-content">
        <div class="modal-header bg-primary text-white">
          <h5 class="modal-title">Edit Note</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <input type="hidden" id="EditNoteId" name="EditNoteId" />
          <textarea id="EditNoteContent" name="EditNoteContent" class="form-control" rows="4"></textarea>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-success">Save Changes</button>
        </div>
      </form>
    </div>
  </div>

  <form method="post" asp-page-handler="SetThreshold" class="mb-3">
    <label for="UniversalThreshold" class="form-label">Set Universal Low-Stock Threshold:</label>
    <input type="number" name="UniversalThreshold" class="form-control w-25 d-inline-block"
      value="@ViewData["Threshold"]" />
    <button type="submit" class="btn btn-sm btn-outline-primary">Update</button>
  </form>

@if (Model.LowStockProducts.Any())
{
    <h4>🔴 Products Below Universal Threshold (@ViewData["Threshold"]):</h4>
    <ul class="list-group mb-4">
      @foreach (var item in Model.LowStockProducts)
      {
        <li class="list-group-item text-danger">
          <strong>@item.Name</strong> — Quantity: @item.Quantity
        </li>
      }
    </ul>
}

@if (Model.WatchedLowProducts.Any())
{
    <h4>🟠 Watched Products Below Individual Threshold:</h4>
    <ul class="list-group mb-4">
      @foreach (var item in Model.WatchedLowProducts)
      {
        <li class="list-group-item text-warning">
          <strong>@item.Name</strong> — Quantity: @item.Quantity
        </li>
      }
    </ul>
}

<script src="https://cdnjs.cloudflare.com/ajax/libs/quagga/0.12.1/quagga.min.js"></script>
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<!-- Scanner Modal -->
<div class="modal fade" id="scannerModal" tabindex="-1" aria-labelledby="scannerModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header bg-info text-white">
        <h5 class="modal-title" id="scannerModalLabel">Product Scanner</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body pb-2">

        <div class="pt-2">
          <div id="barcode-result" class="mb-2 text-center text-success fw-bold small"></div>
          <h6 class="mb-2">Scanned Items</h6>
          <ul id="scanned-items" class="list-group mb-2"></ul>
          <div class="fw-bold">Total: $<span id="total-price">0.00</span></div>
        </div>

        <div id="scanner" class="border p-2 text-center position-relative" style="min-height: 240px; overflow: hidden;">
          <video id="barcode-video" width="100%" class="position-absolute top-0 start-0 h-100 w-100 object-fit-cover" autoplay playsinline muted></video>
        </div>

      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
        <button type="button" class="btn btn-success" onclick="completeTransaction()">Complete Transaction</button>
      </div>
    </div>
  </div>
</div>

@section Scripts {
  @{
    var productNames = Model.Products.Select(p => p.Name).ToList();
    var quantities = Model.Products.Select(p => p.Quantity).ToList();
    var prices = Model.Products.Select(p => p.Price).ToList();
    var reorderLevels = Model.Products.Select(p => p.ReorderLevel).ToList();
    var categoryGroups = Model.Products
    .GroupBy(p => p.Category ?? "Uncategorized")
    .Select(g => new { Category = g.Key, TotalQty = g.Sum(p => p.Quantity) })
    .ToList();
    var priceQuantityPoints = Model.Products
    .Select(p => new { x = p.Price, y = p.Quantity })
    .ToList();
  }

    <script>
      let scannerActive = false;
      const scannedItems = [];
      const scanBufferTime = 1500; // 1.5 seconds buffer
      let lastScannedAt = 0;

      function startScanner() {
          if (scannerActive) return;

          Quagga.init({
              inputStream: {
                  name: "Live",
                  type: "LiveStream",
                  target: document.querySelector('#scanner'),
                  constraints: {
                      width: 640,
                      height: 480,
                      facingMode: "environment"
                  }
              },
              decoder: {
                  readers: ["code_128_reader", "ean_reader", "ean_8_reader", "code_39_reader"]
              }
          }, function (err) {
              if (err) {
                  console.error(err);
                  return;
              }
              Quagga.start();
              scannerActive = true;
          });

          Quagga.onDetected(function (data) {
              const now = new Date().getTime();
              if (now - lastScannedAt < scanBufferTime) return;
              lastScannedAt = now;

              const scannedCode = data.codeResult.code;
              handleScannedBarcode(scannedCode);
          });
      }

      function stopScanner() {
          if (scannerActive) {
              Quagga.stop();
              scannerActive = false;
          }
      }

      // Handle barcode scan, send SKU to backend, and update UI
      function handleScannedBarcode(code) {
        const skuRegex = /^\S+(-\S+){1,3}$/;
        if (!skuRegex.test(code)) {
          $('#barcode-result').text("Invalid SKU format.");
          return;
        }

        const formData = new FormData();
        formData.append('sku', code);

        const token = $('input[name="__RequestVerificationToken"]').val();
        if (token) {
          formData.append('__RequestVerificationToken', token);
        }

        $.ajax({
          url: '/InventoryManagerLanding?handler=ScanBarcode',
          method: 'POST',
          data: formData,
          contentType: false,
          processData: false,
          success: function (response) {
            if (response && response.includes('|')) {
              const [name, sku, price, quantity] = response.split('|');
              addScannedItem({ name, sku, price: parseFloat(price), quantity: 1 });
              $('#barcode-result').text(`Scanned: ${name}`);
            } else {
              $('#barcode-result').text("Product not found.");
            }
          },
          error: function () {
            $('#barcode-result').text("Error retrieving product.");
          }
        });
      }


  function addScannedItem(product) {
    const existing = scannedItems.find(item => item.sku === product.sku);

    if (existing) {
      existing.quantity += 1;
    } else {
      scannedItems.push({ ...product });
    }

    updateScannedList();
  }

  function updateScannedList() {
    const list = document.getElementById('scanned-items');
    list.innerHTML = '';

    let total = 0;

    scannedItems.forEach(item => {
      const li = document.createElement('li');
      li.className = 'list-group-item';
      const subtotal = (item.price * item.quantity).toFixed(2);
      li.textContent = `${item.name} - Qty: ${item.quantity} - $${subtotal}`;
      list.appendChild(li);

      total += item.price * item.quantity;
    });

    document.getElementById('total-price').textContent = total.toFixed(2);
  }

      document.getElementById('scannerModal').addEventListener('shown.bs.modal', function () {
          document.getElementById('barcode-result').innerText = '';
          scannedItems.length = 0; 
          updateScannedList(); 
          startScanner(); 
      });

      document.getElementById('scannerModal').addEventListener('hidden.bs.modal', function () {
          stopScanner(); 
      });

      function completeTransaction() {
    if (scannedItems.length === 0) {
      $('#barcode-result').text("No items to complete.");
      return;
    }

    const formData = new FormData();
    scannedItems.forEach((item, index) => {
      formData.append(`Items[${index}].SKU`, item.sku);
      formData.append(`Items[${index}].Quantity`, item.quantity);
    });

    const token = $('input[name="__RequestVerificationToken"]').val();
    if (token) {
      formData.append('__RequestVerificationToken', token);
    }

    $.ajax({
      url: '/InventoryManagerLanding?handler=CompleteTransaction',
      method: 'POST',
      data: formData,
      contentType: false,
      processData: false,
      success: function (response) {
        if (response === 'success') {
          $('#barcode-result').text("Transaction complete. Inventory updated.");
          scannedItems.length = 0;
          updateScannedList();
        } else {
          $('#barcode-result').text("Transaction failed.");
        }
      },
      error: function () {
        $('#barcode-result').text("Transaction failed.");
      }
    });
  }
    </script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
      // DB data for charts
      const productLabels = @Html.Raw(Json.Serialize(productNames));
      const productQuantities = @Html.Raw(Json.Serialize(quantities));
      const productPrices = @Html.Raw(Json.Serialize(prices));
      const reorderLevels = @Html.Raw(Json.Serialize(reorderLevels));
      const categoryLabels = @Html.Raw(Json.Serialize(@categoryGroups.Select(g => g.Category)));
      const categoryData = @Html.Raw(Json.Serialize(@categoryGroups.Select(g => g.TotalQty)));
      const priceQuantityPoints = @Html.Raw(Json.Serialize(priceQuantityPoints));

      // Clock
      function updateClock() {
        document.getElementById("live-clock").textContent = new Date().toLocaleString();
      }
      setInterval(updateClock, 1000);
      updateClock();

      // Weather
      fetch('https://api.weather.gov/gridpoints/SEW/124,67/forecast')
        .then(res => res.json())
        .then(data => {
          document.getElementById("weather-widget").innerHTML = data.properties.periods[0].detailedForecast;
        })
        .catch(() => document.getElementById("weather-widget").innerHTML = "Weather unavailable.");

      // Calendar
      document.addEventListener('DOMContentLoaded', function () {
        const calendarBody = document.getElementById('calendar-body');
        const currentMonthYear = document.getElementById('current-month-year');
        const prevMonthBtn = document.getElementById('prev-month');
        const nextMonthBtn = document.getElementById('next-month');
        const modalDate = document.getElementById('modal-date');
        const modalNotesContent = document.getElementById('modal-notes-content');

        // Corrected safe serialization
        const notes = @Html.Raw(Json.Serialize(Model.Notes));

        let currentDate = new Date();

        function buildCalendar(year, month) {
          calendarBody.innerHTML = "";

          const firstDay = new Date(year, month, 1);
          const lastDay = new Date(year, month + 1, 0);
          currentMonthYear.textContent = firstDay.toLocaleString('default', { month: 'long', year: 'numeric' });

          let dateCounter = 1 - firstDay.getDay();

          for (let week = 0; week < 6; week++) {
            let row = document.createElement('tr');

            for (let day = 0; day < 7; day++, dateCounter++) {
              let cell = document.createElement('td');
              if (dateCounter > 0 && dateCounter <= lastDay.getDate()) {
                let cellDate = new Date(year, month, dateCounter).toISOString().split('T')[0];
                let notesForDay = notes.filter(note => note.timestamp.startsWith(cellDate));
                let notesLink = notesForDay.length ? `<a href="#" class="calendar-note-link" data-date="${cellDate}">Notes (${notesForDay.length})</a>` : '';
                cell.innerHTML = `<div>${dateCounter}</div>${notesLink}`;
              } else {
                cell.innerHTML = '';
              }
              row.appendChild(cell);
            }
            calendarBody.appendChild(row);
          }

          document.querySelectorAll('.calendar-note-link').forEach(link => {
            link.addEventListener('click', function (e) {
              e.preventDefault();
              let selectedDate = this.getAttribute('data-date');
              modalDate.textContent = selectedDate;
              displayNotes(selectedDate);
              new bootstrap.Modal(document.getElementById('calendarNoteModal')).show();
            });
          });
        }

        function displayNotes(date) {
          modalNotesContent.innerHTML = '';
          let dailyNotes = notes.filter(note => note.timestamp.startsWith(date));
          dailyNotes.forEach(note => {
            let noteElement = document.createElement('div');
            noteElement.className = 'mb-2';
            noteElement.innerHTML = `<small>${new Date(note.timestamp).toLocaleTimeString()}</small><p>${note.content}</p>`;
            modalNotesContent.appendChild(noteElement);
          });
        }

        function updateCalendar(monthOffset) {
          currentDate.setMonth(currentDate.getMonth() + monthOffset);
          buildCalendar(currentDate.getFullYear(), currentDate.getMonth());
        }

        prevMonthBtn.addEventListener('click', () => updateCalendar(-1));
        nextMonthBtn.addEventListener('click', () => updateCalendar(1));

        buildCalendar(currentDate.getFullYear(), currentDate.getMonth());
      });

      // Edit Note Modal
      function openEditModal(noteId, noteContent) {
        document.getElementById('EditNoteId').value = noteId;
        document.getElementById('EditNoteContent').value = noteContent;
        new bootstrap.Modal(document.getElementById('editNoteModal')).show();
      }

      //  Download Chart
      function downloadChart() {
        const chartId = document.getElementById("exportChartType").value;
        const canvas = document.getElementById(chartId);
        const link = document.createElement('a');
        link.download = `${chartId}.png`;
        link.href = canvas.toDataURL();
        link.click();
      }

      // Chart Switcher
      function switchChart(type) {
        const charts = ["stockBarChart", "categoryPieChart", "reorderLineChart", "priceQuantityScatter"];
        document.getElementById("loadingSpinner").style.display = "block";
        setTimeout(() => {
          charts.forEach(id => document.getElementById(id).style.display = "none");
          if (type === "stock") document.getElementById("stockBarChart").style.display = "block";
          if (type === "category") document.getElementById("categoryPieChart").style.display = "block";
          if (type === "reorder") document.getElementById("reorderLineChart").style.display = "block";
          if (type === "scatter") document.getElementById("priceQuantityScatter").style.display = "block";
          document.getElementById("loadingSpinner").style.display = "none";
        }, 800); // simulate loading time
      }

      // Chart.js initialization (example for stockBarChart)

      new Chart(document.getElementById('stockBarChart'), {
        type: 'bar',
        data: {
          labels: productLabels,
          datasets: [{
            label: 'Quantity in Stock',
            data: productQuantities,
            backgroundColor: 'rgba(54, 162, 235, 0.7)'
          }]
        },
        options: {
          responsive: true,
          plugins: {
            legend: { position: 'top' },
            title: { display: true, text: 'Stock Quantity by Product' }
          }
        }
      });

      new Chart(document.getElementById('categoryPieChart'), {
        type: 'pie',
        data: {
          labels: categoryLabels,
          datasets: [{
            data: categoryData,
            backgroundColor: ['#ff6384', '#36a2eb', '#ffce56', '#4bc0c0', '#9966ff', '#f67019']
          }]
        },
        options: {
          plugins: {
            title: { display: true, text: 'Inventory Distribution by Category' }
          }
        }
      });

      new Chart(document.getElementById('reorderLineChart'), {
        type: 'line',
        data: {
          labels: productLabels,
          datasets: [
            {
              label: 'Quantity',
              data: productQuantities,
              borderColor: 'green',
              fill: false,
              tension: 0.3
            },
            {
              label: 'Reorder Level',
              data: reorderLevels,
              borderColor: 'red',
              borderDash: [5, 5],
              fill: false,
              tension: 0.3
            }
          ]
        },
        options: {
          responsive: true,
          plugins: {
            title: {
              display: true,
              text: 'Stock Levels vs Reorder Thresholds'
            }
          },
          scales: {
            y: {
              beginAtZero: true
            }
          }
        }
      });

      new Chart(document.getElementById('priceQuantityScatter'), {
        type: 'scatter',
        data: {
          datasets: [{
            label: 'Products',
            data: priceQuantityPoints,
            backgroundColor: 'rgba(75, 192, 192, 0.7)'
          }]
        },
        options: {
          responsive: true,
          plugins: {
            title: {
              display: true,
              text: 'Price vs Quantity per Product'
            }
          },
          scales: {
            x: {
              title: { display: true, text: 'Price ($)' }
            },
            y: {
              title: { display: true, text: 'Quantity' },
              beginAtZero: true
            }
          }
        }
      });
    </script>
}
