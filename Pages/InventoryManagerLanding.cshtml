@page
@model IMS.Pages.InventoryManagerLandingModel
@{
  ViewData["Title"] = "Inventory Manager Dashboard";
}

<!-- Header with Log Out Button -->
<div class="d-flex justify-content-between align-items-center mb-4">
  <h1>Inventory Manager Dashboard</h1>
  <form method="post">
    <button type="submit" asp-page-handler="Logout" class="btn btn-danger">Log Out</button>
  </form>
</div>

@if (ViewData.ModelState[""]?.Errors?.Count > 0)
{
  <div class="alert alert-warning">
    @ViewData.ModelState[""]?.Errors?.FirstOrDefault()?.ErrorMessage
  </div>
}

<!-- Top Quick Info Bar -->
<div class="row mb-4">
  <div class="col-md-6">
    <h4>Weather</h4>
    <div id="weather-widget" class="border p-3">
      <p>TODO: Integrate weather API Current: 72°F, Sunny</p>
    </div>
  </div>
  <div class="col-md-6 text-right">
    <h4>Quick Order</h4>
    <div id="quick-order" class="border p-3">
      <button class="btn btn-success">Order Products</button>
    </div>
  </div>
</div>

<!-- Display Current Date and Time with Live Refresh -->
<div class="row mb-4">
  <div class="col-md-12 text-center">
    <h4>Current Date & Time</h4>
    <div class="border p-3">
      <p id="live-clock">@Model.CurrentTime.ToString("f")</p>
    </div>
  </div>
</div>

<!-- Main Content Grid -->
<div class="row">
  <!-- Left Panel: Quick Product Search -->
  <div class="col-md-6">
    <div class="card mb-4">
      <div class="card-header">Quick Product Search</div>
      <div class="card-body">
        <form method="get" class="mb-3">
          <div class="form-group">
            <input type="text" name="SearchTerm" value="@Model.SearchTerm" class="form-control"
              placeholder="Search for a product by name, description, category, or SKU..." />
          </div>
          <button type="submit" class="btn btn-primary">Search</button>
        </form>
        @if (!string.IsNullOrEmpty(Model.SearchTerm) && Model.Products != null && Model.Products.Count > 0)
        {
          <ul class="list-group">
            @foreach (var product in Model.Products)
            {
              <li class="list-group-item">
                <strong>@product.Name</strong> - $@product.Price, Qty: @product.Quantity
              </li>
            }
          </ul>
        }
        else if (!string.IsNullOrEmpty(Model.SearchTerm))
        {
          <p>No products found.</p>
        }
      </div>
    </div>
  </div>

  <!-- Right Panel: Notes & Calendar -->
  <div class="col-md-6">
    <div class="card mb-4">
      <div class="card-header">Notes</div>
      <div class="card-body">
        <h6>Recent Notes</h6>
        @if (Model.Notes != null && Model.Notes.Count > 0)
        {
          <ul class="list-group">
            @foreach (var note in Model.Notes)
            {
              <li class="list-group-item">
                <small>@note.Timestamp.ToString("f")</small> - @note.Content
              </li>
            }
          </ul>
        }
        else
        {
          <p>No notes yet.</p>
        }
      </div>
    </div>
    <div class="card">
      <div class="card-header">Calendar</div>
      <div class="card-body">
        <div id="calendar" style="max-width: 100%; margin: 0 auto; min-height: 300px;"></div>
      </div>
    </div>
  </div>
</div>

<!-- Modal for Adding Notes -->
<div class="modal fade" id="noteModal" tabindex="-1" aria-labelledby="noteModalTitle" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="noteModalTitle">Add Note</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <form method="post">
          <input type="hidden" id="selectedDate" name="SelectedDate" />
          <div class="form-group">
            <textarea name="NewNote" class="form-control" placeholder="Enter note here..." rows="3"></textarea>
          </div>
          <button type="submit" class="btn btn-primary mt-2">Save Note</button>
        </form>
      </div>
    </div>
  </div>
</div>

@section Scripts {
  <link href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.8/main.min.css" rel="stylesheet" />
  <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.8/main.min.js"></script>

  <script>
    document.addEventListener('DOMContentLoaded', function () {
      var calendarEl = document.getElementById('calendar');
      var calendar = new FullCalendar.Calendar(calendarEl, {
        initialView: 'dayGridMonth',
        selectable: true,
        dateClick: function (info) {
          document.getElementById('selectedDate').value = info.dateStr;
          document.getElementById('noteModalTitle').innerText = "Add Note for " + info.dateStr;
          var noteModal = new bootstrap.Modal(document.getElementById('noteModal'));
          noteModal.show();
        },
        events: function (fetchInfo, successCallback, failureCallback) {
          fetch('/InventoryManagerLanding?handler=CalendarEvents')
            .then(response => response.json())
            .then(data => successCallback(data))
            .catch(error => console.error('Error fetching events:', error));
        }
      });
      calendar.render();
    });
  </script>
}
