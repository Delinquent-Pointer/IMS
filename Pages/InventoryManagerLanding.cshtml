@page
@model IMS.Pages.InventoryManagerLandingModel
@{
  ViewData["Title"] = "Inventory Manager Dashboard";
}

<!-- Header with Log Out Button -->
<div class="d-flex justify-content-between align-items-center mb-4">
  <h1>Inventory Manager Dashboard</h1>
  <form method="post">
    <button type="submit" asp-page-handler="Logout" class="btn btn-danger">Log Out</button>
  </form>
</div>

@if (!ViewData.ModelState.IsValid)
{
  <div class="alert alert-warning">
    @ViewData.ModelState[""]?.Errors.FirstOrDefault()?.ErrorMessage
  </div>
}

<!-- Top Quick Info Bar -->
<div class="row mb-4">
  <!-- Weather Widget -->
  <div class="col-md-6">
    <h4>Weather</h4>
    <div id="weather-widget" class="border p-3">
      @if (!string.IsNullOrEmpty(Model.WeatherInfo))
      {
        <p><strong>@Model.WeatherInfo</strong></p>
      }
      else
      {
        <p><strong>Loading Weather...</strong></p>
      }
    </div>
  </div>

  <!-- Time Widget -->
  <div class="col-md-6 text-right">
    <h4>Current Time</h4>
    <div id="time-widget" class="border p-3">
      <p><strong>Loading Time...</strong></p>
    </div>
  </div>
</div>

<!-- Main Content Grid -->
<div class="row">
  <div class="col-md-6">
    <div class="card mb-4">
      <div class="card-header">Product Search</div>
      <div class="card-body">
        <form method="get" class="mb-3">
          <div class="form-group">
            <input type="text" name="SearchTerm" value="@Model.SearchTerm" class="form-control"
              placeholder="Search for a product by name or description..." />
          </div>
          <button type="submit" class="btn btn-primary">Search</button>
        </form>
        @if (Model.Products.Any())
        {
          <ul class="list-group">
            @foreach (var product in Model.Products)
            {
              <li class="list-group-item">
                <strong>@product.Name</strong> - $@product.Price, Qty: @product.Quantity
              </li>
            }
          </ul>
        }
        else
        {
          <p>No products found.</p>
        }
      </div>
    </div>
  </div>

  <!-- Right Panel: Notes & Calendar -->
  <div class="col-md-6">
    <div class="card mb-4">
      <div class="card-header">Notes</div>
      <div class="card-body">
        <form method="post">
          <div class="form-group">
            <textarea name="NewNote" class="form-control" placeholder="Enter note here..." rows="3"></textarea>
          </div>
          <button type="submit" class="btn btn-secondary mt-2">Save Note</button>
        </form>
        <hr />
        <h6>Recent Notes</h6>
        @if (Model.Notes.Any())
        {
          <ul class="list-group">
            @foreach (var note in Model.Notes)
            {
              <li class="list-group-item">
                <small>@note.Timestamp.ToString("g")</small> - @note.Content
              </li>
            }
          </ul>
        }
        else
        {
          <p>No notes yet.</p>
        }
      </div>
    </div>

    <div class="card">
      <div class="card-header">Calendar</div>
      <div class="card-body">
        <div id="calendar" style="max-width: 100%; margin: 0 auto; min-height: 300px;"></div>
      </div>
    </div>
  </div>
</div>

@section Scripts {
  <!-- FullCalendar CDN -->
  <link href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.8/main.min.css" rel="stylesheet" />
  <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.8/main.min.js"></script>

  <script>
    document.addEventListener('DOMContentLoaded', function () {
      // Load Local Time
      setInterval(updateTime, 1000);
      updateTime(); // Initial call

      // Initialize Calendar
      var calendarEl = document.getElementById('calendar');
      var calendar = new FullCalendar.Calendar(calendarEl, {
        initialView: 'dayGridMonth',
        headerToolbar: {
          left: 'prev,next today',
          center: 'title',
          right: 'dayGridMonth,timeGridWeek,timeGridDay'
        },
        events: async function (fetchInfo, successCallback, failureCallback) {
          try {
            let response = await fetch('/api/events');
            let events = await response.json();
            successCallback(events);
          } catch (error) {
            console.error("Failed to load events", error);
            failureCallback(error);
          }
        }
      });

      calendar.render();
    });

    // Update Time
    function updateTime() {
      let timeWidget = document.getElementById("time-widget");
      let now = new Date();
      let options = { timeZone: "@Model.UserTimeZone", hour: "2-digit", minute: "2-digit", second: "2-digit" };
      timeWidget.innerHTML = `<p><strong>Local Time:</strong> ${now.toLocaleTimeString("en-US", options)}</p>`;
    }
  </script>
}
