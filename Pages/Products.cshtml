@page
@model IMS.Pages.ProductsModel
@{
  ViewData["Title"] = "Products";
  int selectedProductId = 0;
}

<h1>Product Search Index</h1>

<form method="get">
  <div class="row align-items-end g-2">  
    <div class="col-md-3">
      <label>Search Category:</label>
      <select name="SearchType" id="SearchType" asp-for="SearchType" class="form-control">
        <option value="Name" selected>Name</option>
        <option value="Description">In Description</option>
        <option value="Price">Price (matching "=", above "&gt;", below "&lt;")</option>
        <option value="Quantity">Quantity (matching "=", above "&gt;", below "&lt;")</option>
        <option value="SKU">SKU</option>
        <option value="Category">Category</option>
        <option value="Location">Location</option>
        <option value="AdvQuery">Advanced Query</option>
      </select>
    </div>

    <div class="col-md-2" id="operatorDiv" style="display: none;">
      <label for="Operator">Comparison Operator:</label>
      <select name="Operator" id="Operator" asp-for="Operator" class="form-control">
        <option value="=" selected>=</option>
        <option value=">">&gt;</option>
        <option value=">=">&ge;</option>
        <option value="<">&lt;</option>
        <option value="<=">&le;</option>
      </select>
    </div>

    <div class="col-md-4">
      <label for="SearchTerm">Search Term:</label>
      <input type="text" name="SearchTerm" value="@Model.SearchTerm" class="form-control"
        placeholder="enter search term" />
    </div>
    <div class="col-md-2 d-grid">
      <button type="submit" class="btn btn-primary">Search</button>
    </div>
  </div>  
</form>

<style>
  .clickable-row:hover {
    border: 2px solid #0d6efd !important; /* Bootstrap primary blue */
    cursor: pointer; 
  }

  .description-cutoff {
    display: -webkit-box;
    -webkit-line-clamp: 2; /* cutoff description text after 2 lines */
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-overflow: ellipsis; /* add "..." at cutoff */ 
    word-break: break-word; /* cutoff can split long words*/
    white-space: normal;
  }
</style>

<script>
  function toggleDropdown() {
    var operatorDiv = document.getElementById('operatorDiv');
    var searchType = document.getElementById('SearchType').value;
    operatorDiv.style.display = (searchType === 'Price' || searchType === 'Quantity') ? 'block' : 'none';
  }

  document.getElementById('SearchType').addEventListener('change', toggleDropdown);
  window.onload = toggleDropdown;
</script>


<div style="overflow-y: auto; max-height: 700px; border: 1px solid #ddd;">
  <table class="table table-striped mt-3">
    <thead style="position: sticky; top: 0; z-index: 1;">
      <tr>
        <th>Name</th>
        <th>Description</th>
        <th>Price</th>
        <th>Quantity</th>
        <th>SKU</th>
        <th>Category</th>
        <th>Location</th>
      </tr>
    </thead>
    <tbody>
      @if (Model.Products != null && Model.Products.Count > 0)
      {
          foreach (var product in Model.Products)
          {
              var imageBase64 = product.Image != null ? Convert.ToBase64String(product.Image) : null;
              <tr class="clickable-row" data-bs-toggle="modal" data-bs-target="#productModal"
                  data-id="@product.Id" 
                  data-name="@product.Name" data-description="@product.Description"
                  data-price="@product.Price" data-quantity="@product.Quantity"
                  data-reorder-level="@product.ReorderLevel"
                  data-sku="@product.SKU" data-category="@product.Category"
                  data-location="@product.Location" data-image="@imageBase64">
                  <td>@product.Name</td>
                  <td style= "max-width: 500px;">
                    <div class="description-cutoff" title="@product.Description">
                    @product.Description
                    </div>
                  </td>
                  <td>$@product.Price</td>
                  <td>@product.Quantity</td>
                  <td>@product.SKU</td>
                  <td>@product.Category</td>
                  <td>@product.Location</td>
              </tr>
          }
      }
      else
      {
          <tr><td colspan="7" class="text-center">No products found.</td></tr>
      }
    </tbody>
  </table>
</div>

<div class="modal fade" id="productModal" tabindex="-1" aria-labelledby="productModalLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="productModalLabel">Product Details</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <form method="post" asp-page-handler="EditProduct" id="editProductForm" enctype="multipart/form-data">
          <input type="hidden" id="modalProductId" name="Input.Id">

          <div class="mb-2">
            <img id="modalProductImage" src="" alt="Product Image" class="img-fluid" style="max-width: 200px; max-height: 200px;" />
          </div>

          <div class="mb-2">
            <label><strong>Product Image:</strong></label>
            <input type="file" id="imageFileInput" name="Input.ImageFile" class="form-control mt-2" style="display: none;" />
          </div>

          <div class="mb-2">
            <label><strong>Name:</strong></label>
            <input type="text" id="modalProductName" name="Input.ProductName" class="form-control" disabled>
          </div>

          <div class="mb-2">
            <label><strong>Description:</strong></label>
            <textarea id="modalProductDescription" name="Input.Description" class="form-control" disabled></textarea>
          </div>

          <div class="mb-2">
            <label><strong>Price ($):</strong></label>
            <input type="number" id="modalProductPrice" name="Input.Price" class="form-control" step="0.01" disabled>
          </div>

          <div class="mb-2">
            <label><strong>Quantity:</strong></label>
            <input type="number" id="modalProductQuantity" name="Input.Quantity" class="form-control" disabled>
          </div>

          <div class="mb-2">
            <label><strong>Reorder Level:</strong></label>
            <input type="number" id="modalProductReorderLevel" name="Input.ReorderLevel" class="form-control" disabled>
          </div>

          <div class="mb-2">
            <label><strong>SKU:</strong></label>
            <input type="text" id="modalProductSKU" name="Input.SKU" class="form-control" disabled>
          </div>

          <div class="mb-2">
            <label><strong>Category:</strong></label>
            <input type="text" id="modalProductCategory" name="Input.Category" class="form-control" disabled>
          </div>

          <div class="mb-2">
            <label><strong>Location:</strong></label>
            <input type="text" id="modalProductLocation" name="Input.Location" class="form-control" disabled>
          </div>

          <div class="modal-footer">
            <button type="button" class="btn btn-danger" data-bs-toggle="modal" data-bs-target="#deleteProductModal">Delete</button>
            <button type="button" id="editButton" class="btn btn-warning">Edit</button>
            <button type="submit" id="saveButton" class="btn btn-success" style="display: none;">Save Changes</button>
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>


<div class="modal fade" id="deleteProductModal" tabindex="-1" aria-labelledby="deleteProductModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="deleteProductModalLabel">Confirm Deletion</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" Style="text-align: center; font-weight: bold; color: rgb(255, 123, 0);">
                Are you sure you want to delete this product?
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <form method="post" asp-page-handler="Delete">
                    <input type="hidden" id="deleteProductId" name="id" />
                    <button type="submit" class="btn btn-danger">Confirm</button>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
  document.addEventListener("DOMContentLoaded", function () {
      var rows = document.querySelectorAll(".clickable-row");
      var editButton = document.getElementById("editButton");
      var saveButton = document.getElementById("saveButton");
      var formInputs = document.querySelectorAll("#editProductForm input, #editProductForm textarea");
      var imageElement = document.getElementById("modalProductImage");
      var fileInput = document.getElementById("imageFileInput");

      var deleteProductModal = document.getElementById("deleteProductModal");
      var deleteProductIdInput = document.getElementById("deleteProductId");

      rows.forEach(row => {
          row.addEventListener("click", function () {
              document.getElementById("modalProductId").value = this.dataset.id || "";
              selectedProductId = this.dataset.id || 0; // Store the selected product ID for deletion
              document.getElementById("modalProductName").value = this.dataset.name || "";
              document.getElementById("modalProductDescription").value = this.dataset.description || "";
              document.getElementById("modalProductPrice").value = this.dataset.price || "";
              document.getElementById("modalProductQuantity").value = this.dataset.quantity || "";
              document.getElementById("modalProductReorderLevel").value = this.dataset.reorderLevel || "";
              document.getElementById("modalProductSKU").value = this.dataset.sku || "";
              document.getElementById("modalProductCategory").value = this.dataset.category || "";
              document.getElementById("modalProductLocation").value = this.dataset.location || "";

              var productImageData = this.dataset.image;
              if (productImageData) {
                  imageElement.src = 'data:image/jpeg;base64,' + productImageData; 
              } else {
                  imageElement.src = '/images/default-product-image.png'; // Set a default image if no image exists
              }

              formInputs.forEach(input => input.disabled = true);
              saveButton.style.display = "none";
              editButton.style.display = "inline-block";
          });
      });

      editButton.addEventListener("click", function () {
          formInputs.forEach(input => input.disabled = false);
          saveButton.style.display = "inline-block";
          editButton.style.display = "none";
          fileInput.style.display = "block"; 
      });

      // Handle delete modal logic
      var deleteProductModal = document.getElementById("deleteProductModal");
      deleteProductModal.addEventListener("show.bs.modal", function () {
          // Set the delete modal's hidden input field to the selected product ID
          deleteProductIdInput.value = selectedProductId;
      });
  });
</script>

<div class="mt-3 d-flex justify-content-between align-items-center">
  <div>
      <label style="font-weight: bold" for="csvInput">Upload CSV</label>
      <form class="d-flex" method="post" asp-page-handler="UploadCSV" enctype="multipart/form-data">
        <input type="file" class="form-control w-auto" name ="file" accept=".csv"/>
        <button type="submit" class="btn btn-primary">Upload</button>
      </form>
  </div>

	<div>
		<label style="font-weight: bold" for="csvInput">Download CSV</label>
		<form class="d-flex" method="post" asp-page-handler="DownloadCSV">
            @foreach (var product in Model.Products){
                <input type="hidden" name="ProductIds" value="@product.Id" />
            }
            <button type="submit" class="btn btn-success">Download</button>
		</form>
    </div>
</div>

<div class="modal fade" id="errorModal" tabindex="-1" aria-labelledby="errorModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="errorModalLabel">Errors</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <ul id="errorList" class="list-group"  >
                </ul>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
      var errors = @Html.Raw(Json.Serialize(ViewData["Errors"] ?? new List<string>()));
      if (errors.length > 0) {
        var errorList = document.getElementById("errorList");
        errors.forEach(function (error) {
          var li = document.createElement("li");
          li.className = "list-group-item";
          li.textContent = error;
		  li.style.color = "red";
          errorList.appendChild(li);
        });
        var errorModal = new bootstrap.Modal(document.getElementById("errorModal"));
        errorModal.show();
      }
    });
</script>