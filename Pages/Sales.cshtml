@page
@model IMS.Pages.SalesModel
@{
    ViewData["Title"] = "Sales";
}

<div class="container mt-5">
    <h1 class="text-center">Sales Page</h1>
    @foreach (var sale in Model.SalesTransactions)
    {
        <div class="card my-4">
            <div class="card-header">
                <strong>Transaction ID:</strong> @sale.Id |
                <strong>Timestamp:</strong> @sale.Timestamp |
                <strong>Total:</strong> $@sale.TotalAmount
            </div>
            <div class="card-body p-0">
                <table class="table table-striped mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Product</th>
                            <th>SKU</th>
                            <th>Quantity</th>
                            <th>Price Each</th>
                            <th>Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in sale.Items)
                        {
                            <tr>
                                <td>@item.ProductName</td>
                                <td>@item.SKU</td>
                                <td>@item.QuantityRemoved</td>
                                <td>$@item.PriceAtSale</td>
                                <td>$@(item.PriceAtSale * item.QuantityRemoved)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>
